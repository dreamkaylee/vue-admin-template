{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "include": [
    "env.d.ts",
    "build/**/*.ts",
    "types/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "types": ["node", "vite/client"],
  "typeRoots": ["./types", "./node_modules/@types"],
  "references": [
    {
      "path": "./tsconfig.config.json"
    }
  ]
}
